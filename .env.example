# Skopiuj ten plik jako .env i uzupelnij swoje dane polaczenia
# cp .env.example .env

# Oracle database connection settings
DB_USER=your_username
DB_PASS=your_password
DB_HOST=localhost
DB_PORT=1521
DB_SERVICE=XE

# Nazwa pod jaka polaczenie bedzie zapisane w SQLcl (dowolna)
CONN_NAME=my_oracle

# Sciezka do SQLcl (pobierz z https://www.oracle.com/database/sqldeveloper/technologies/sqlcl/download/)
SQLCL_PATH=C:\tools\sqlcl\bin\sql.exe
